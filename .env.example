# Observability backends
LOKI_URL=http://loki:3100
PROMETHEUS_URL=http://prometheus:9090

# HTTP probes (comma-separated)
PROBE_URLS=http://devplanner:3000/health,http://devplanner:3000/

# Remote host over Tailscale (read-only SSH)
TAILSCALE_HOST=100.x.y.z
SSH_USER=deploy
SSH_KEY_PATH=/data/ssh/id_ed25519

# AWS Bedrock
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ntfy.sh
NTFY_TOPIC=your-unique-topic-name

# SQLite (shared between agent and API in Docker)
DB_PATH=/data/verdicts.db

# Docker socket (optional; leave empty to skip docker events tool)
DOCKER_HOST=
