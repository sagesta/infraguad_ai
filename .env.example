# GCP / Vertex AI
GCP_PROJECT_ID=infraguard-ai
GCP_REGION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/gcp-key.json

# Target app (DevPlanner)
LOKI_URL=http://100.64.0.x:3100
PROMETHEUS_URL=http://100.64.0.x:9090
TAILSCALE_HOST=100.64.0.x
SSH_USER=monitor
SSH_KEY_PATH=/run/secrets/ssh-key

# Notifications
NTFY_TOPIC=infraguard-devplanner
PROBE_URLS=http://100.64.0.x:3000/health,http://100.64.0.x:3000/api/health

# SQLite (shared between agent and API in Docker)
DB_PATH=/data/verdicts.db

# Docker socket (optional; leave empty to skip docker events tool)
DOCKER_HOST=
