# ─── Auth ───
INFRAGUARD_USERNAME=admin
INFRAGUARD_PASSWORD=changeme
SECRET_KEY=your-random-secret-key-here

# ─── GCP / Vertex AI ───
GCP_PROJECT_ID=your-project-id
GCP_REGION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/gcp-key.json

# ─── Target App ───
DEVPLANNER_CONTAINER_NAME=devplanner-api

# ─── Loki (cloud instance URL for Promtail push) ───
LOKI_URL=http://<GCE_VM_IP>:3100

# ─── Prometheus ───
PROMETHEUS_URL=http://prometheus:9090

# ─── Containers to inspect on critical severity ───
MONITORED_CONTAINERS=devplanner-api

# ─── Notifications ───
NTFY_TOPIC=infraguard-devplanner
PROBE_URLS=https://yourapp.com,https://api.yourapp.com

# ─── SQLite (shared between agent and API in Docker) ───
DB_PATH=/data/verdicts.db

# ─── Docker Engine API (optional) ───
DOCKER_HOST=

# ─── Notion (for RAG runbooks) ───
NOTION_TOKEN=your-notion-integration-token
NOTION_DATABASE_ID=your-database-id

# ─── CrowdSec (optional — app works in dry-run without this) ───
CROWDSEC_API_URL=
CROWDSEC_API_KEY=

# ─── LangChain Agent (set to 1 to use multi-tool reasoning) ───
USE_LANGCHAIN_AGENT=0

# ─── Heartbeat ───
HEARTBEAT_INTERVAL_SECONDS=60
