# GCP / Vertex AI
GCP_PROJECT_ID=infraguard-ai
GCP_REGION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/gcp-key.json

# Target app (DevPlanner) — use Docker Compose service names on the same host network
DEVPLANNER_API_URL=http://devplanner-api:3000
LOKI_URL=http://loki:3100
PROMETHEUS_URL=http://prometheus:9090

# Containers to inspect on critical severity (actual names: docker ps --format {{.Names}})
MONITORED_CONTAINERS=devplanner-api

# Notifications
NTFY_TOPIC=infraguard-devplanner
PROBE_URLS=http://devplanner-api:3000/health,http://devplanner-api:3000/api/health

# SQLite (shared between agent and API in Docker)
DB_PATH=/data/verdicts.db

# Docker Engine API (optional override; default is unix socket inside the agent container)
DOCKER_HOST=
